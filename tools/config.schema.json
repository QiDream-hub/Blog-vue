{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Blog Publisher 配置",
  "description": "博客发布工具的配置文件",
  "type": "object",
  "properties": {
    "lmjwebApi": {
      "type": "string",
      "format": "uri",
      "description": "lmjweb 服务地址",
      "example": "http://localhost:8080"
    },
    "blogInfoPtr": {
      "type": "string",
      "pattern": "^01[a-f0-9]{32}$",
      "description": "博客信息对象指针",
      "example": "01blog0000000000000000000000000000"
    },
    "imagesDir": {
      "type": "string",
      "description": "图片文件存放目录（Nginx alias 路径）",
      "example": "/var/www/images"
    },
    "articlesDir": {
      "type": "string",
      "description": "文章内容存放目录（Nginx alias 路径）",
      "example": "/var/www/articles"
    }
  },
  "required": ["lmjwebApi", "blogInfoPtr", "imagesDir", "articlesDir"]
}
